name: |-
  Remini
desc: |-
  无

http:

  mitm:
    - "*.oracle.bendingspoonsapps.com"

  script:  
  - match: ^https?:\/\/.*\.oracle\.bendingspoonsapps\.com\/v\d\/(users\/.+|purchases\/verify)
    name: Remini_8
    type: response
    require-body: true
    max-size: -1
    timeout: 60


script-providers:
  "Remini_8":
    url: https://raw.githubusercontent.com/axtyet/ios/main/QuantumultX/cyz_13724/scripts/ReminiLifetime.js
    interval: 86400

